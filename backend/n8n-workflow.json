        "genericAuthType": "httpBasicAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"data\": {\n    \"attributes\": {\n      \"line_items\": [\n        {\n          \"currency\": \"PHP\",\n          \"amount\": {{$json.body.amount * 100}},\n          \"description\": \"MisoCash Wallet Funding\",\n          \"name\": \"Wallet Deposit\",\n          \"quantity\": 1\n        }\n      ],\n      \"payment_method_types\": [\"gcash\", \"paymaya\", \"card\"],\n      \"success_url\": \"https://misocash.app/success\",\n      \"cancel_url\": \"https://misocash.app/cancel\",\n      \"description\": \"Funding for {{ $json.body.mobile }}\",\n      \"metadata\": {\n         \"mobile\": \"{{ $json.body.mobile }}\"\n      }\n    }\n  }\n}",
        "options": {}
      },
      "name": "PayMongo API Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [360, 800],
