        "query": "=INSERT INTO users (name, mobile, email, balance, mpin, biometric_enabled) \nVALUES ('{{$json.body.name}}', '{{$json.body.mobile}}', '{{$json.body.email}}', {{$json.body.balance}}, '{{$json.body.mpin}}', {{$json.body.biometric_enabled}})\nON DUPLICATE KEY UPDATE \nname = '{{$json.body.name}}', \nemail = '{{$json.body.email}}', \nbalance = {{$json.body.balance}}, \nmpin = '{{$json.body.mpin}}', \nbiometric_enabled = {{$json.body.biometric_enabled}};"
      },
