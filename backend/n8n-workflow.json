{
  "name": "Spending Tracker AI Workflow",
  "nodes": [
    {
      "parameters": {
        "path": "spending-input",
        "responseMode": "lastNode"
      },
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "create",
        "model": "gpt-3.5-turbo",
        "prompt": "=Categorize the following transaction. Return ONLY a valid JSON object with EXACTLY these keys: \"amount\" (number, e.g. 180), \"type\" (string, either \"income\" or \"expense\"), \"category\" (string, e.g. \"Food\", \"Transportation\"), \"description\" (string).\n\nTransaction: {{$json.body.raw_input}}\nLocal Context: {{$json.body.location_context}}"
      },
      "id": "2",
      "name": "OpenAI",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "operation": "insert",
        "table": "transactions",
        "columns": "amount, type, category, description",
        "dataMode": "define",
        "values": {
          "value": [
            {
              "column": "amount",
              "value": "={{JSON.parse($json.message.content).amount}}"
            },
            {
              "column": "type",
              "value": "={{JSON.parse($json.message.content).type}}"
            },
            {
              "column": "category",
              "value": "={{JSON.parse($json.message.content).category}}"
            },
            {
              "column": "description",
              "value": "={{JSON.parse($json.message.content).description}}"
            }
          ]
        }
      },
      "id": "3",
      "name": "Insert into MySQL",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 1,
      "position": [650, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "OpenAI",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "OpenAI": {
      "main": [
        [
          {
            "node": "Insert into MySQL",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {}
}
